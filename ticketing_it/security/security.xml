<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- =============================================
             SECURITY GROUPS
             NOTE: No implied_ids — this prevents the
             base.group_user rule from overriding our
             custom group rules and showing all tickets
             to everyone.
        ============================================= -->

        <record id="group_line_manager" model="res.groups">
            <field name="name">Line Manager</field>
        </record>

        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
        </record>

        <record id="group_it_team" model="res.groups">
            <field name="name">IT Support Team</field>
        </record>

        <!-- =============================================
             RECORD RULES

             HOW ODOO RULES WORK:
             - Rules on SAME group = combined with OR
             - Rules on DIFFERENT groups user belongs
               to = combined with AND
             - No rule on a group = full access

             STRATEGY:
             - Portal users  → restricted by create_uid
             - Line Manager  → restricted to their team
             - IT Team       → restricted to assigned
             - IT Manager    → no restriction (all)
             - base.group_user has NO rule so internal
               users not in custom groups see nothing
               (because custom group rules apply as AND)
        ============================================= -->

        <!-- PORTAL USER: sees only tickets they created -->
        <record id="rule_it_ticket_portal" model="ir.rule">
            <field name="name">Portal: Own Tickets Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- LINE MANAGER (Dinesh Rampal):
             Sees ONLY tickets where line_manager_id = him.
             Tickets get line_manager_id from employee.parent_id.user_id
             So all employees who have Dinesh as their manager
             will appear here when they raise tickets. -->
        <record id="rule_it_ticket_line_manager" model="ir.rule">
            <field name="name">Line Manager: Team Tickets Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[('line_manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_line_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- IT SUPPORT TEAM (Zeeshan):
             Sees ONLY tickets that have been assigned to them.
             assigned_to_id is set when IT Manager assigns work. -->
        <record id="rule_it_ticket_it_team" model="ir.rule">
            <field name="name">IT Team: Assigned Tickets Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[('assigned_to_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_it_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- IT MANAGER (Usama):
             Sees ALL tickets — no restriction.
             domain_force (1=1) means always true. -->
        <record id="rule_it_ticket_it_manager" model="ir.rule">
            <field name="name">IT Manager: All Tickets</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>