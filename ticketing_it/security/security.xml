<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ===================================================== -->
        <!-- GROUPS -->
        <!-- ===================================================== -->

        <record id="group_line_manager" model="res.groups">
            <field name="name">Line Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_it_team" model="res.groups">
            <field name="name">IT Support Team</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>


        <!-- ===================================================== -->
        <!-- PORTAL USER RULE -->
        <!-- Portal users see ONLY their own tickets -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_portal" model="ir.rule">
            <field name="name">IT Ticket - Portal Own Tickets</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                [('create_uid', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- ===================================================== -->
        <!-- LINE MANAGER RULE -->
        <!-- Only tickets waiting for THEIR approval -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_line_manager" model="ir.rule">
            <field name="name">IT Ticket - Line Manager Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                [
                    ('line_manager_id', '=', user.id),
                    ('state', '=', 'manager_approval')
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_line_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- ===================================================== -->
        <!-- IT MANAGER RULE -->
        <!-- Only tickets waiting for IT approval -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_it_manager" model="ir.rule">
            <field name="name">IT Ticket - IT Manager Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                [
                    ('it_manager_id', '=', user.id),
                    ('state', '=', 'it_approval')
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- ===================================================== -->
        <!-- IT TECHNICIAN RULE -->
        <!-- Only tickets assigned to them -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_it_team" model="ir.rule">
            <field name="name">IT Ticket - IT Technician Only</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                [
                    ('assigned_to_id', '=', user.id),
                    ('state', 'in', ['assigned', 'in_progress'])
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_it_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- ===================================================== -->
        <!-- ADMIN RULE -->
        <!-- System Admin sees everything -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_admin_all" model="ir.rule">
            <field name="name">IT Ticket - Admin Full Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>