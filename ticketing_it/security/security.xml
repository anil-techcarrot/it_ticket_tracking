<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ===================================================== -->
        <!-- GROUPS                                                 -->
        <!-- ===================================================== -->

        <record id="group_line_manager" model="res.groups">
            <field name="name">Line Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_it_manager" model="res.groups">
            <field name="name">IT Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_it_team" model="res.groups">
            <field name="name">IT Support Team</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- ===================================================== -->
        <!-- PORTAL RULE                                            -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_portal" model="ir.rule">
            <field name="name">IT Ticket - Portal Own Tickets</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===================================================== -->
        <!-- GLOBAL RULE                                            -->
        <!-- CREATOR: always sees own tickets                       -->
        <!-- LINE MANAGER: sees from manager_approval onwards      -->
        <!-- IT MANAGER: sees from it_approval onwards             -->
        <!-- IT TECHNICIAN: ONLY sees tickets assigned to them     -->
        <!--   with state filter so unassigned tickets dont show   -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_global_internal" model="ir.rule">
            <field name="name">IT Ticket - Global Internal Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|', '|', '|',
                    ('create_uid', '=', user.id),
                    '&amp;', ('line_manager_id', '=', user.id),
                             ('state', 'in', ['manager_approval', 'it_approval', 'assigned', 'in_progress', 'done', 'rejected']),
                    '&amp;', ('it_manager_id', '=', user.id),
                             ('state', 'in', ['it_approval', 'assigned', 'in_progress', 'done', 'rejected']),
                    '&amp;', ('assigned_to_id', '=', user.id),
                             ('state', 'in', ['assigned', 'in_progress', 'done'])
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===================================================== -->
        <!-- LINE MANAGER WRITE RULE                               -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_line_manager_write" model="ir.rule">
            <field name="name">IT Ticket - Line Manager Write Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                ['&amp;',
                    ('line_manager_id', '=', user.id),
                    ('state', 'in', ['manager_approval', 'it_approval', 'assigned', 'in_progress', 'done', 'rejected'])
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_line_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===================================================== -->
        <!-- IT MANAGER WRITE RULE                                 -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_it_manager_write" model="ir.rule">
            <field name="name">IT Ticket - IT Manager Write Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                ['&amp;',
                    ('it_manager_id', '=', user.id),
                    ('state', 'in', ['it_approval', 'assigned', 'in_progress', 'done', 'rejected'])
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_it_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===================================================== -->
        <!-- IT TEAM WRITE RULE                                    -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_it_team_write" model="ir.rule">
            <field name="name">IT Ticket - IT Team Write Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">
                ['&amp;',
                    ('assigned_to_id', '=', user.id),
                    ('state', 'in', ['assigned', 'in_progress', 'done'])
                ]
            </field>
            <field name="groups" eval="[(4, ref('ticketing_it.group_it_team'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- ===================================================== -->
        <!-- ADMIN RULE                                            -->
        <!-- ===================================================== -->

        <record id="rule_it_ticket_admin" model="ir.rule">
            <field name="name">IT Ticket - Admin Full Access</field>
            <field name="model_id" ref="model_it_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>