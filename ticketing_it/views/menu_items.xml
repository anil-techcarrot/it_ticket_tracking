<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ROOT MENU: points to different actions per role -->
    <!-- For portal/employee — their own tickets -->
    <menuitem id="menu_it_tickets_root"
              name="IT Tickets"
              action="action_it_ticket_my"
              sequence="10"/>

    <!-- ALL USERS: My Tickets (tickets they created) -->
    <menuitem id="menu_it_tickets_my"
              name="My Tickets"
              parent="menu_it_tickets_root"
              action="action_it_ticket_my"
              sequence="10"/>

    <!-- LINE MANAGER ONLY -->
    <menuitem id="menu_it_tickets_pending_manager"
              name="Pending My Approval"
              parent="menu_it_tickets_root"
              action="action_it_ticket_pending_manager"
              groups="ticketing_it.group_line_manager"
              sequence="20"/>

    <menuitem id="menu_it_tickets_my_team"
              name="My Team Tickets"
              parent="menu_it_tickets_root"
              action="action_it_ticket_my_team"
              groups="ticketing_it.group_line_manager"
              sequence="25"/>

    <!-- IT MANAGER ONLY -->
    <menuitem id="menu_it_tickets_pending_it"
              name="Pending IT Approval"
              parent="menu_it_tickets_root"
              action="action_it_ticket_pending_it"
              groups="ticketing_it.group_it_manager"
              sequence="30"/>

    <menuitem id="menu_it_tickets_it_all"
              name="All IT Tickets"
              parent="menu_it_tickets_root"
              action="action_it_ticket_it_all"
              groups="ticketing_it.group_it_manager"
              sequence="35"/>

    <!-- IT TECHNICIAN ONLY -->
    <menuitem id="menu_it_tickets_assigned_to_me"
              name="My Assigned Tickets"
              parent="menu_it_tickets_root"
              action="action_it_ticket_assigned_to_me"
              groups="ticketing_it.group_it_team"
              sequence="40"/>

    <!-- ADMIN ONLY -->
    <menuitem id="menu_it_tickets_all"
              name="All Tickets"
              parent="menu_it_tickets_root"
              action="action_it_ticket_all"
              groups="base.group_system"
              sequence="5"/>

</odoo>