<odoo>

    <!-- Search View with Open/Closed Filter Buttons -->
    <record id="view_it_ticket_dashboard_search" model="ir.ui.view">
        <field name="name">it.ticket.dashboard.search</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <search string="IT Tickets">
                <filter
                    string="Open Tickets"
                    name="filter_open"
                    domain="[('state','in',['draft','manager_approval','it_approval','assigned','in_progress'])]"/>
                <filter
                    string="Closed Tickets"
                    name="filter_closed"
                    domain="[('state','in',['done','rejected'])]"/>
            </search>
        </field>
    </record>

    <!-- Single Graph View -->
    <record id="view_it_ticket_graph_dashboard" model="ir.ui.view">
        <field name="name">it.ticket.graph.dashboard</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <graph string="Tickets by Type" type="pie">
                <field name="ticket_type"/>
            </graph>
        </field>
    </record>

    <!-- Dashboard Action — opens with Open Tickets filter active by default -->
    <record id="action_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_it_ticket_graph_dashboard"/>
        <field name="search_view_id" ref="view_it_ticket_dashboard_search"/>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>

    <menuitem id="menu_dashboard"
              parent="menu_it_tickets_root"
              action="action_dashboard"
              sequence="5"
              name="Dashboard"/>

</odoo>