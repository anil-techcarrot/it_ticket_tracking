<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================= -->
    <!-- LIST VIEW                     -->
    <!-- ============================= -->

    <record id="view_it_ticket_list" model="ir.ui.view">
        <field name="name">it.ticket.list</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <list string="IT Tickets" default_order="create_date desc">
                <field name="name" string="Ticket #"/>
                <field name="employee_id"/>
                <field name="ticket_type"/>
                <field name="priority" widget="priority"/>
                <field name="state"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state in ['manager_approval','it_approval']"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>


    <!-- ============================= -->
    <!-- FORM VIEW                     -->
    <!-- ============================= -->

    <record id="view_it_ticket_form" model="ir.ui.view">
        <field name="name">it.ticket.form</field>
        <field name="model">it.ticket</field>
        <field name="arch" type="xml">
            <form string="IT Ticket">

                <header>

                    <!-- Submit: Employee submits their own draft ticket -->
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <!-- Line Manager Approve: visible to Line Manager only when pending -->
                    <!-- NO groups attr — Python enforces who can click -->
                    <button name="action_manager_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'manager_approval'"/>

                    <!-- Reject: visible when ticket is pending any approval -->
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-secondary"
                            invisible="state not in ['manager_approval', 'it_approval']"/>

                    <!-- IT Manager Approve: visible when pending IT -->
                    <!-- NO groups attr — Python enforces who can click -->
                    <button name="action_it_approve"
                            string="IT Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'it_approval'"/>

                    <!-- IT Technician Start Work -->
                    <button name="action_start_work"
                            string="Start Work"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'assigned'"/>

                    <!-- IT Technician Mark Done -->
                    <button name="action_done"
                            string="Mark Done"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'in_progress'"/>

                    <!-- Status bar -->
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,manager_approval,it_approval,assigned,in_progress,done"/>

                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="ticket_type"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="subject"/>
                            <field name="required_date"/>
                            <field name="line_manager_id" readonly="1"/>
                            <field name="it_manager_id" readonly="1"/>
                            <field name="assigned_to_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Rejection Info"
                              invisible="state != 'rejected'">
                            <group>
                                <field name="rejected_by_id"/>
                                <field name="rejected_date"/>
                                <field name="rejection_reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>

            </form>
        </field>
    </record>


    <!-- ============================= -->
    <!-- ACTIONS                       -->
    <!-- ============================= -->

    <!-- ALL USERS: Own created tickets -->
    <record id="action_it_ticket_my" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
    </record>

    <!-- LINE MANAGER: Pending approval -->
    <record id="action_it_ticket_pending_manager" model="ir.actions.act_window">
        <field name="name">Pending My Approval</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('line_manager_id', '=', uid),
            ('state', '=', 'manager_approval')
        ]</field>
    </record>

    <!-- LINE MANAGER: Team tickets -->
    <record id="action_it_ticket_my_team" model="ir.actions.act_window">
        <field name="name">My Team Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('line_manager_id', '=', uid),
            ('state', 'in', ['draft', 'manager_approval', 'rejected'])
        ]</field>
    </record>

    <!-- IT MANAGER: Pending IT approval -->
    <record id="action_it_ticket_pending_it" model="ir.actions.act_window">
        <field name="name">Pending IT Approval</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('it_manager_id', '=', uid),
            ('state', '=', 'it_approval')
        ]</field>
    </record>

    <!-- IT MANAGER: All tickets they manage -->
    <record id="action_it_ticket_it_all" model="ir.actions.act_window">
        <field name="name">All IT Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('it_manager_id', '=', uid),
            ('state', 'in', ['it_approval', 'assigned', 'in_progress', 'done', 'rejected'])
        ]</field>
    </record>

    <!-- IT TECHNICIAN: Only assigned tickets -->
    <record id="action_it_ticket_assigned_to_me" model="ir.actions.act_window">
        <field name="name">My Assigned Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('assigned_to_id', '=', uid)
        ]</field>
    </record>

    <!-- ADMIN: All tickets -->
    <record id="action_it_ticket_all" model="ir.actions.act_window">
        <field name="name">All Tickets</field>
        <field name="res_model">it.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>

</odoo>